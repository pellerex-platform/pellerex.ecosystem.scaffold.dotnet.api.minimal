<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<clear />
		<add key="Nuget" value="https://api.nuget.org/v3/index.json" />
		<add key="Common" value="https://pkgs.dev.azure.com/Pellerex/Public/_packaging/CommonLibrary/nuget/v3/index.json" />
	</packageSources>
	<!--
	  Pin Pellerex-owned packages to the private Common feed so a same-named package
	  published to nuget.org can never be resolved instead (dependency-confusion guard).
	  Everything else resolves only from nuget.org.
	-->
	<packageSourceMapping>
		<packageSource key="Common">
			<package pattern="Pellerex.*" />
		</packageSource>
		<packageSource key="Nuget">
			<package pattern="*" />
		</packageSource>
	</packageSourceMapping>
</configuration>